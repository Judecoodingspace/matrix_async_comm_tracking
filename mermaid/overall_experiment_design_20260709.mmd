flowchart TD
    TITLE["实验总设计速览<br>从 回填是否有效 收紧为 遮挡中迟到支撑何时值得在线使用"]:::title

    TITLE --> S0

    subgraph G0["阶段0 旧路线证伪"]
        S0["M3OT 回填主线关闭"]:::fail
        E0["证据<br>全局回填 0.557 小于丢弃 0.656<br>事件门控 0.628 仍小于丢弃"]:::evidence
        S0 -.-> E0
    end

    S0 --> S1

    subgraph G1["阶段1 MATRIX 真值世界坐标机制"]
        S1["MATRIX 数据可用"]:::pass
        E1["标准<br>身份 世界坐标 标定 LoS 可用<br>收紧 排除检测器和外观噪声"]:::evidence
        S1 -.-> E1

        S2["异步时序机制成立"]:::pass
        E2["证据<br>捕获时刻融合保持上界<br>到达时刻融合随延迟退化"]:::evidence
        S2 -.-> E2

        S3["2 帧有害阈值稳定"]:::pass
        E3["证据<br>多个窗口均在 fixed_2 越过安全边界"]:::evidence
        S3 -.-> E3
    end

    S1 --> S2
    S2 --> S3
    S3 --> S4

    subgraph G2["阶段A 几何门控边界"]
        S4["时间戳不是充分条件"]:::partial
        E4["证据<br>时间抖动和0.50m坐标噪声下<br>普通时间戳融合低于丢弃"]:::evidence
        S4 -.-> E4

        S5["几何门控只能控害<br>不能证明净收益为正"]:::partial
        E5["证据<br>v2c 优于 plain uncertain<br>但仍低于 drop-delayed<br>支撑净边际值为负"]:::evidence
        S5 -.-> E5
    end

    S4 --> S5
    S5 --> S6

    subgraph G3["阶段B前置 遮挡支撑因果审计"]
        S6["场景收窄到主视角遮挡"]:::pass
        E6["理由<br>主视角缺证据时<br>support 才有明显边际价值"]:::evidence
        S6 -.-> E6

        S7["遮挡 delay-ratio 描述审计"]:::partial
        E7["结论<br>离线上界不足以说明在线边界<br>rho_episode 只能事后诊断"]:::evidence
        S7 -.-> E7

        S8["因果在线回放审计"]:::partial
        E8["结论<br>500ms 有强在线价值<br>1000ms 后快速下降"]:::evidence
        S8 -.-> E8

        S9["成对反事实测量校准"]:::pass
        E9["标准<br>Run A 复现 mismatch 0<br>mask mismatch 0<br>不使用真值身份修轨迹"]:::evidence
        S9 -.-> E9
    end

    S6 --> S7
    S7 --> S8
    S8 --> S9
    S9 --> S10

    subgraph G4["阶段B前置 时间边界解释"]
        S10["0-999 时间边界扩展"]:::pass
        E10["结论<br>M4 delay coverage interaction<br>优于 delay only<br>但旧 cell gate 过硬"]:::evidence
        S10 -.-> E10

        S11["matched diagnostics 完成"]:::pass
        E11["结论<br>当前机制为 early-frame gap<br>早期发布帧缺 support 是主因"]:::evidence
        S11 -.-> E11

        CURRENT["当前位置<br>online proxy readiness 已执行<br>结论 online_proxy_weak"]:::current
        EC["证据<br>M5 F1 提升 0.076<br>AUC 只提升 0.003<br>frame proxy 强但 episode ranking 增量不足"]:::currentEvidence
        CURRENT -.-> EC
    end

    S10 --> S11
    S11 --> CURRENT
    CURRENT --> N1

    subgraph G5["下一步计划"]
        N1["动作阈值校准审计"]:::plan
        EN1["标准<br>同等 harmful accept 下<br>M5 保留更多 helpful support<br>重点 1000ms 和 1500ms"]:::planEvidence
        N1 -.-> EN1

        N2["加入坐标噪声和空间陈旧"]:::plan
        EN2["标准<br>验证 v delay 除以 gate radius<br>是否成为第三维边界"]:::planEvidence
        N2 -.-> EN2

        N3["消息内容消融"]:::plan
        EN3["标准<br>坐标 bbox pose 身份线索<br>作为信息维度贡献不同"]:::planEvidence
        N3 -.-> EN3
    end

    N1 --> N2
    N2 --> N3

    SUMMARY["一眼结论<br>已证实迟到观测影响身份跟踪<br>已证实遮挡中短延迟 support 有在线价值<br>已证实 episode rho 过粗<br>当前不直接进入 policy learning<br>下一步做动作阈值校准"]:::summary

    CURRENT --> SUMMARY

